rules_version = '2';

// =====================================================================
// CAST MANAGER WEB — Firestore Security Rules (PR1〜PR5)
//
// 設計方針:
// - 未承認(pending) / 無効(disabled) / usersドキュメント不在 のユーザーは
//   業務データへ一切アクセスできない（読み取りも不可）。
// - users の新規作成は「自分自身・role=viewer・status=pending」のみ。
//   role / status / accessibleStoreIds をユーザー自身が引き上げることは
//   不可能。
// - role / status / accessibleStoreIds / approvedAt / approvedBy /
//   disabledAt の変更は、PR5でCloud Functions専用となった
//   （クライアントSDKからはowner含め誰も直接変更できない。本人が変更
//   できるのは displayName / updatedAt のみ）。承認・権限変更・無効化・
//   最後のowner保護は functions/src/index.ts のCallable Functionsが
//   Admin SDK（Rulesをバイパス）のトランザクション内で実行する。
// - 業務データは storeId によるアクセス制御。owner は全店舗。
//   admin / viewer は accessibleStoreIds に含まれる店舗のみ。
// - 書き込みは admin 以上。viewer は読み取り専用。
// - auditLogs は追記のみ（更新・削除不可）。owner のみ閲覧可。
// - キャストの完全削除（PR5）は owner のみ、許可店舗内であれば無条件で
//   許可。関連データ（monthlyResults/interviews/goals/motivations/
//   wageHistory）の削除・nameMatchingRulesのリンク解除は
//   castDeleteService が担う。admin以下は従来どおりExcelインポートの
//   Batch単位ロールバックに限定した削除のみ許可。
// =====================================================================

service cloud.firestore {
  match /databases/{database}/documents {

    // ---------- 共通ヘルパー ----------
    function isSignedIn() {
      return request.auth != null;
    }

    function userPath(uid) {
      return /databases/$(database)/documents/users/$(uid);
    }

    function userDocExists() {
      return isSignedIn() && exists(userPath(request.auth.uid));
    }

    function me() {
      return get(userPath(request.auth.uid)).data;
    }

    function isApproved() {
      return userDocExists() && me().status == 'approved';
    }

    function isOwner() {
      return isApproved() && me().role == 'owner';
    }

    function isAdminOrAbove() {
      return isApproved() && me().role in ['owner', 'admin'];
    }

    // 対象storeIdへのアクセス権（ownerは全店舗）
    function canAccessStore(storeId) {
      return isApproved()
        && (me().role == 'owner' || storeId in me().accessibleStoreIds);
    }

    // ---------- users ----------
    match /users/{uid} {

      // 自分のドキュメントは読める。ownerは全ユーザーを読める。
      allow get: if isSignedIn() && (request.auth.uid == uid || isOwner());
      allow list: if isOwner();

      // 新規作成: 本人のみ・viewer/pending固定・店舗アクセス空
      allow create: if isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.role == 'viewer'
        && request.resource.data.status == 'pending'
        && request.resource.data.accessibleStoreIds is list
        && request.resource.data.accessibleStoreIds.size() == 0
        && request.resource.data.email is string
        && request.resource.data.displayName is string
        && request.resource.data.approvedAt == null
        && request.resource.data.approvedBy == null
        && request.resource.data.disabledAt == null;

      // 更新: 本人が displayName / updatedAt のみをクライアントから更新できる。
      //
      // role / status / accessibleStoreIds / approvedAt / approvedBy /
      // disabledAt の変更は PR5 で Cloud Functions（functions/src/index.ts の
      // approveUser / changeUserRole / disableUser / enableUser /
      // setAccessibleStores）へ移行し、クライアントSDKからの直接書き込みは
      // ここで全面的に禁止する。Cloud FunctionsはAdmin SDKで動作し
      // Security Rulesをバイパスするため、この制限と矛盾しない。
      // 「最後の承認済みownerの降格・無効化禁止」もCloud Functions側の
      // トランザクション内クエリで厳密に保証される（PR1〜4時点の
      // クライアント側チェックのみに依存しない）。
      allow update: if
        isSignedIn()
        && request.auth.uid == uid
        && request.resource.data.diff(resource.data).affectedKeys()
             .hasOnly(['displayName', 'updatedAt']);

      // 削除は不可（無効化=status:'disabled'で扱う）
      allow delete: if false;
    }

    // ---------- 店舗マスター ----------
    match /stores/{storeId} {
      // 承認済みユーザーは店舗一覧を読める（店舗切替UIのため）
      allow read: if isApproved();
      // 店舗の作成・編集は owner のみ。createdBy/updatedBy の偽装を禁止。
      allow create: if isOwner()
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid;
      allow update: if isOwner()
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedBy == request.auth.uid;
      allow delete: if false; // 非表示(active:false)で扱う
    }

    // ---------- 業務データ（店舗別アクセス制御・admin以上で書込） ----------
    match /casts/{docId} {
      allow read: if canAccessStore(resource.data.storeId);
      // 作成: admin以上・許可店舗のみ・'__all__'禁止・createdBy/updatedByは本人
      // archived:true での作成は owner のみ許可（旧データ移行でアーカイブ済み
      // キャストを移すため。admin以下は従来どおり archived:false のみ）
      allow create: if isAdminOrAbove()
        && canAccessStore(request.resource.data.storeId)
        && request.resource.data.storeId != '__all__'
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid
        && (request.resource.data.archived == false || isOwner());
      // 更新: storeId変更禁止（許可外店舗への移動を含む）・
      //       createdBy/createdAt改竄禁止・updatedByは本人
      allow update: if isAdminOrAbove()
        && canAccessStore(resource.data.storeId)
        && request.resource.data.storeId == resource.data.storeId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedBy == request.auth.uid;
      // 完全削除（PR5）: owner のみ、許可店舗内であれば任意のキャストを
      // 削除できる（関連データの削除は castDeleteService が担う）。
      // 例外: Excelインポートが新規作成したキャスト（importBatchId付き）のみ、
      // Batch単位ロールバックのため許可店舗のadminも削除できる。
      allow delete: if canAccessStore(resource.data.storeId)
        && (
          isOwner()
          || (
            isAdminOrAbove()
            && resource.data.keys().hasAny(['importBatchId'])
            && resource.data.importBatchId is string
          )
        );
    }

    match /monthlyResults/{docId} {
      allow read: if canAccessStore(resource.data.storeId);
      allow create: if isAdminOrAbove()
        && canAccessStore(request.resource.data.storeId)
        && request.resource.data.storeId != '__all__'
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid;
      allow update: if isAdminOrAbove()
        && canAccessStore(resource.data.storeId)
        && request.resource.data.storeId == resource.data.storeId
        && request.resource.data.castId == resource.data.castId
        && request.resource.data.month == resource.data.month
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedBy == request.auth.uid;
      // 月別成績の削除は既存ローカル版でも可能なため admin 以上に許可
      allow delete: if isAdminOrAbove() && canAccessStore(resource.data.storeId);
    }

    match /interviews/{docId} {
      allow read: if canAccessStore(resource.data.storeId);
      allow create: if isAdminOrAbove()
        && canAccessStore(request.resource.data.storeId)
        && request.resource.data.storeId != '__all__'
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid;
      allow update: if isAdminOrAbove()
        && canAccessStore(resource.data.storeId)
        && request.resource.data.storeId == resource.data.storeId
        && request.resource.data.castId == resource.data.castId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedBy == request.auth.uid;
      allow delete: if isAdminOrAbove() && canAccessStore(resource.data.storeId);
    }

    match /motivations/{docId} {
      allow read: if canAccessStore(resource.data.storeId);
      allow create: if isAdminOrAbove()
        && canAccessStore(request.resource.data.storeId)
        && request.resource.data.storeId != '__all__'
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid;
      allow update: if isAdminOrAbove()
        && canAccessStore(resource.data.storeId)
        && request.resource.data.storeId == resource.data.storeId
        && request.resource.data.castId == resource.data.castId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedBy == request.auth.uid;
      allow delete: if isAdminOrAbove() && canAccessStore(resource.data.storeId);
    }

    match /goals/{docId} {
      allow read: if canAccessStore(resource.data.storeId);
      allow create: if isAdminOrAbove()
        && canAccessStore(request.resource.data.storeId)
        && request.resource.data.storeId != '__all__'
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid;
      allow update: if isAdminOrAbove()
        && canAccessStore(resource.data.storeId)
        && request.resource.data.storeId == resource.data.storeId
        && request.resource.data.castId == resource.data.castId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedBy == request.auth.uid;
      allow delete: if isAdminOrAbove() && canAccessStore(resource.data.storeId);
    }


    match /wageHistory/{docId} {
      allow read: if canAccessStore(resource.data.storeId);
      // 時給履歴は追記のみ（改竄防止）
      allow create: if isAdminOrAbove()
        && canAccessStore(request.resource.data.storeId)
        && request.resource.data.storeId != '__all__'
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if false;
      // 削除: owner は許可店舗内であれば任意の履歴を削除できる（キャスト
      // 完全削除のため）。owner以外は Excelインポートが追加した履歴
      // （source: excel-import）のみ、Batch単位ロールバックのため削除可。
      // それ以外の手動・移行の履歴はowner以外削除不可のまま
      allow delete: if canAccessStore(resource.data.storeId)
        && (
          isOwner()
          || (
            isAdminOrAbove()
            && resource.data.keys().hasAny(['source'])
            && resource.data.source == 'excel-import'
          )
        );
    }

    // ---------- インポート履歴（owner / 許可店舗のadminのみ作成） ----------
    match /importBatches/{docId} {
      // 閲覧は許可店舗のみ（viewerは既存設計どおり読み取りは可・画面は非表示）
      allow read: if canAccessStore(resource.data.storeId);
      // 作成: owner または許可店舗のadminのみ。createdBy偽装・'__all__'禁止
      allow create: if isAdminOrAbove()
        && canAccessStore(request.resource.data.storeId)
        && request.resource.data.storeId != '__all__'
        && request.resource.data.createdBy == request.auth.uid;
      // 更新: 実行完了時の件数・状態・変更記録、ロールバック結果の書き込みのみ。
      // storeId / createdBy / createdAt / fileName / targetMonth は改竄禁止。
      // rollbackBy を書き込む場合は本人のuidのみ（偽装禁止）
      allow update: if isAdminOrAbove()
        && canAccessStore(resource.data.storeId)
        && request.resource.data.storeId == resource.data.storeId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.fileName == resource.data.fileName
        && request.resource.data.targetMonth == resource.data.targetMonth
        && (
          request.resource.data.get('rollbackBy', null) == resource.data.get('rollbackBy', null)
          || request.resource.data.rollbackBy == request.auth.uid
        );
      allow delete: if false;
    }

    // ---------- 旧データ移行の実行記録（owner専用） ----------
    match /migrationRuns/{docId} {
      allow read: if isOwner();
      // 作成・更新は owner のみ。createdBy偽装・startedAt/createdBy改竄禁止
      allow create: if isOwner()
        && request.resource.data.createdBy == request.auth.uid;
      allow update: if isOwner()
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.startedAt == resource.data.startedAt;
      allow delete: if false;
    }

    // ---------- Excelインポート照合ルール（owner / 許可店舗のadminのみ書込） ----------
    match /nameMatchingRules/{docId} {
      // 許可店舗外のルールは読めない。viewerは読み取りのみ（書き込み一切不可）
      allow read: if canAccessStore(resource.data.storeId);
      allow create: if isAdminOrAbove()
        && canAccessStore(request.resource.data.storeId)
        && request.resource.data.storeId != '__all__'
        && request.resource.data.createdBy == request.auth.uid
        && request.resource.data.updatedBy == request.auth.uid;
      // 更新: storeId変更禁止・createdBy/createdAt改竄禁止・updatedByは本人
      allow update: if isAdminOrAbove()
        && canAccessStore(resource.data.storeId)
        && request.resource.data.storeId == resource.data.storeId
        && request.resource.data.createdBy == resource.data.createdBy
        && request.resource.data.createdAt == resource.data.createdAt
        && request.resource.data.updatedBy == request.auth.uid;
      // 削除: owner / 許可店舗のadminのみ（インポートのBatch単位ロールバック用。
      // 通常の無効化は active:false を推奨）。viewerは不可
      allow delete: if isAdminOrAbove() && canAccessStore(resource.data.storeId);
    }

    // ---------- 監査ログ（追記のみ） ----------
    match /auditLogs/{docId} {
      allow read: if isOwner();
      allow create: if isApproved()
        && request.resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // ---------- その他は全拒否 ----------
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
